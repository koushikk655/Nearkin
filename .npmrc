# Hoist packages that Metro/Babel need to resolve at the workspace root level.
# Without these, pnpm keeps them only in the virtual store and Metro can't find them.
public-hoist-pattern[]=@babel/runtime
public-hoist-pattern[]=@babel/runtime-corejs3
public-hoist-pattern[]=@babel/core
public-hoist-pattern[]=react
public-hoist-pattern[]=react-native
public-hoist-pattern[]=react-dom
