# ===========================================
# Neario API — Environment Variables
# Copy this file to .env and fill in real values.
# ===========================================

# --- Server ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- Database (Neon free tier recommended for cost-friendly hosting) ---
# Format: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/neario

# --- JWT ---
# Generate a strong random secret: `openssl rand -base64 64`
JWT_SECRET=replace-with-a-long-random-string
JWT_ACCESS_TOKEN_TTL=7d

# --- Firebase Admin SDK (for OTP verification) ---
# From Firebase console → Project settings → Service accounts → Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# IMPORTANT: Wrap the multi-line key in double quotes and escape newlines with \n
FIREBASE_PRIVATE_KEY=

# --- Razorpay (free test mode available) ---
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=xxx

# --- Cloudinary (free tier: 25 GB storage, 25 GB bandwidth/month) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Google Maps (free tier: $200 credit/month) ---
GOOGLE_MAPS_API_KEY=

# --- Admin ---
# Generate a strong random key for admin-only endpoints
ADMIN_KEY=replace-with-admin-secret

# --- Platform fee (in paise; 5% default applied server-side) ---
PLATFORM_FEE_PERCENT=5

# --- OTP rate limit (per phone, per hour) ---
OTP_REQUEST_LIMIT_PER_HOUR=5

# --- CORS (comma-separated origins, or * for dev) ---
CORS_ORIGINS=*
