# ============================================
# Nearfold Mobile — local env (optional)
# ============================================
#
# The app reads its API base URL from `expo.extra.apiBaseUrl` in app.json.
# Override per-environment via EAS Build secrets or eas.json profile env.
#
# For local dev against a backend on your machine, set this in app.json or
# point apiBaseUrl at your machine's LAN IP (devices on Wi-Fi can reach it
# but cannot reach `localhost`).
#
# Example values:
#   apiBaseUrl: "http://10.0.0.5:3000/api/v1"   # LAN IP for device
#   apiBaseUrl: "http://localhost:3000/api/v1"  # iOS simulator only
#   apiBaseUrl: "https://api.nearfold.com/v1"   # prod

# Firebase config files (DOWNLOAD FROM FIREBASE CONSOLE — do not commit):
#   apps/mobile/GoogleService-Info.plist  (iOS)
#   apps/mobile/google-services.json      (Android)
#
# Both files are referenced from app.json. They are .gitignore'd.
